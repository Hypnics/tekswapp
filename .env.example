NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com

TEKSWAPP_OWNER_EMAILS=owner@yourdomain.com
TEKSWAPP_STAFF_EMAILS=staff1@yourdomain.com,staff2@yourdomain.com

# Optional: only needed when Stripe is enabled
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: override the exchange-rate source or refresh cadence used for browse-price conversion
FX_RATES_API_URL=https://api.frankfurter.dev/v1/latest
FX_RATES_TTL_SECONDS=21600

# Optional for local development only: simulate request geolocation without a provider header
TEKSWAPP_GEO_COUNTRY_OVERRIDE=
